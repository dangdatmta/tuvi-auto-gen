# Daily generation
VIDEO_DATE=
# 1 = 00:00 ICT, 2 = 03:00 ICT, 3 = 06:00 ICT, 4 = 09:00 ICT,
# 5 = 12:00 ICT, 6 = 15:00 ICT, 7 = 18:00 ICT, 8 = 21:00 ICT
RUN_SLOT=
# Sequential content begins here. The first 12 generated slots use Sun Tzu,
# then the pool continues into Confucius/Laozi and loops when exhausted.
VIDEO_SERIES_START_DATE=2026-05-25
VIENEU_VOICE=Tuyen
VIENEU_DIR=
PYTHON_BIN=python

# Gemini copy generation through Vertex AI.
# Required for daily:generate. Authenticate with:
# gcloud auth application-default login
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.8
GEMINI_MAX_RETRIES=2

# Flexible visual planner + generated images.
# Visual plan uses GEMINI_TEXT_MODEL. Images use Vertex AI Imagen by default.
ENABLE_GEMINI_VISUAL_PLAN=true
ENABLE_GEMINI_IMAGES=true
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
IMAGEN_PERSON_GENERATION=allow_adult
IMAGEN_SAFETY_SETTING=block_only_high
VISUAL_BEAT_MIN_SECONDS=3.2
VISUAL_BEAT_MAX_SECONDS=6.5
VISUAL_BEAT_MIN_COUNT=5
VISUAL_BEAT_MAX_COUNT=14

# Render presets:
# social-balanced = 1080x1920, 30fps, ~5 Mbps video bitrate for daily uploads.
# social-small = 1080x1920, 30fps, ~4 Mbps video bitrate for lighter files.
# archive-high = HyperFrames high quality for master renders only.
RENDER_PRESET=social-balanced
RENDER_VIDEO_BITRATE=5M
RENDER_FPS=30

# Local ML subject outline effect
# If dependencies/model fail, generation keeps running and skips this effect.
ENABLE_SUBJECT_OUTLINE=false
ENABLE_SUBJECT_LAYERS=true
SUBJECT_MODEL=isnet-general-use
SUBJECT_MIN_AREA_RATIO=0.015
SUBJECT_MAX_CONTOURS=3
SUBJECT_LAYER_OPACITY=0.92
SUBJECT_SHADOW_OPACITY=0.38
SUBJECT_DEPTH_PUSH=34
SUBJECT_PYTHON_BIN=

# Publishing guard rails
# Keep false locally until every token and permission is ready.
ENABLE_SOCIAL_PUBLISH=false
PUBLISH_DRY_RUN=true

# Optional: publish only selected platforms, comma-separated.
# Valid values: tiktok,youtube-short,facebook-reel
PUBLISH_PLATFORMS=tiktok,youtube-short,facebook-reel

# TikTok Content Posting API
# Draft upload requires Content Posting API access and video.upload scope.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# YouTube Data API
# Requires OAuth consent, refresh token, and youtube.upload scope.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=27

# Facebook Graph API Reels
# Requires a Page access token with the needed Page/video publishing permissions.
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
